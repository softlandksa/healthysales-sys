# Database (Supabase) — MUST use Transaction Pooler (port 6543) for serverless
# Session mode (port 5432) exhausts the 15-connection pool under load
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection — only needed for local `pnpm db:push` / `pnpm db:migrate`
# Do NOT set this on Vercel; it is never used at runtime
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Auth
AUTH_SECRET="my-super-secret-key-123"
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="my-super-secret-key-123"

AUTH_URL="https://your-app.vercel.app"

# App
NEXT_PUBLIC_APP_NAME="نظام إدارة المبيعات الميداني"
NEXT_PUBLIC_APP_VERSION="0.1.0"
